DATABASE_URL="postgresql://ayeye:ayeye_dev@localhost:5432/ayeye?schema=public"
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Interswitch — Passport (OAuth2, shared endpoint)
ISW_PASSPORT_URL=https://qa.interswitchng.com/passport/oauth/token

# Interswitch — General Integration (Paycode / Cardless services)
ISW_CLIENT_ID=your-general-client-id
ISW_SECRET=your-general-secret
ISW_BASE_URL=https://sandbox.interswitchng.com

# Interswitch — Card Payment API (Collections / deposit capture)
ISW_CARD_CLIENT_ID=your-card-client-id
ISW_CARD_SECRET=your-card-secret
ISW_CARD_MERCHANT_CODE=your-card-merchant-code
ISW_CARD_PAY_ITEM_ID=your-card-pay-item-id
ISW_COLLECTIONS_BASE_URL=https://newwebpay.qa.interswitchng.com

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@ayeye.app

# App
FRONTEND_URL=http://localhost:5173
